    "balanced": {
      "gemini": "fast",
      "codex": "fast",
      "claude": "fast"
    },
    "economy": {
      "gemini": "cheap",
      "codex": "cheap",
      "claude": "cheap"
    },
    "custom": {
      "gemini": "default",
      "codex": "default",
      "claude": "default"
    }
  },
  "usage": {
    "warningThresholdPercent": 80,
    "criticalThresholdPercent": 90,
    "claudeStatsPath": "auto",
    "dailyTokenBudget": {
      "claude-opus-4-6": 5000000,
      "claude-sonnet-4-5-20250929": 15000000
    },
    "weeklyTokenBudget": {
      "claude-opus-4-6": 25000000,
      "claude-sonnet-4-5-20250929": 75000000
    },
    "plan": "max_20x",
    "windowHours": 5,
    "windowTokenBudget": {
      "claude-opus-4-6": 2500000,
      "claude-sonnet-4-5-20250929": 7500000
    },
    "sessionBudget": 5000000,
    "perTaskBudget": 500000,
    "perAgentBudget": {
      "claude": 3000000,
      "gemini": 1000000,
      "codex": 1000000
    }
  },
  "verification": {
    "onTaskDone": true,
    "command": "auto",
    "timeoutMs": 60000,
    "secretsScan": true,
    "maxDiffLines": 10000
  },
  "stats": {
    "retentionDays": 30
  },
  "concierge": {
    "enabled": true,
    "model": "gpt-5",
    "reasoningEffort": "low",
    "maxHistoryMessages": 40,
    "autoActivate": true,
    "showProviderInPrompt": true,
    "welcomeMessage": true,
    "fallbackChain": [
      {
        "provider": "openai",
        "model": "gpt-5"
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-5-20250929"
      },
      {
        "provider": "google",
        "model": "gemini-3-flash-preview"
      }
    ]
  },
  "selfAwareness": {
    "enabled": true,
    "injectIntoConcierge": true,
    "includeSnapshot": true,
    "includeIndex": true,
    "snapshotMaxLines": 80,
    "indexMaxChars": 7000,
    "indexRefreshMs": 300000
  },
  "roles": {
    "architect": {
      "agent": "claude",
      "model": null,
      "reasoningEffort": null
    },
    "analyst": {
      "agent": "gemini",
      "model": null,
      "reasoningEffort": null
    },
    "implementer": {
      "agent": "codex",
      "model": null,
      "reasoningEffort": null
    },
    "concierge": {
      "agent": "codex",
      "model": "gpt-5",
      "reasoningEffort": "xhigh"
    },
    "investigator": {
      "agent": "codex",
      "model": "gpt-5.2",
      "reasoningEffort": "high"
    },
    "nightlyHandoff": {
      "agent": "codex",
      "model": "o4-mini",
      "reasoningEffort": null
    }
  },
  "recommendations": {
    "architect": {
      "models": ["claude-sonnet-4-6", "claude-opus-4-6", "gpt-5.4"],
      "reasoningEffort": null,
      "note": "Strong coding + agentic at 40% lower cost than Opus; Opus available for highest-complexity tasks"
    },
    "analyst": {
      "models": ["gemini-3.1-pro-preview", "claude-opus-4-6"],
      "reasoningEffort": null,
      "note": "Latest SOTA reasoning model, GPQA 91.9%, 1M native context"
    },
    "implementer": {
      "models": ["gpt-5.4", "gpt-5.3-codex", "claude-sonnet-4-5-20250929"],
      "reasoningEffort": null,
      "note": "SWE-Bench Pro 57.7%, 1.05M context, reasoning effort control (none→xhigh)"
    },
    "concierge": {
      "models": ["gpt-5", "claude-sonnet-4-5-20250929"],
      "reasoningEffort": null,
      "note": "Fast streaming, broad knowledge, $1.25/$10 (GPT-5 has no reasoning control)"
    },
    "investigator": {
      "models": ["gpt-5.2", "gpt-5"],
      "reasoningEffort": null,
      "note": "Best deep reasoning (GPQA 93.2%, FrontierMath 40.3%)"
    },
    "nightlyHandoff": {
      "models": ["o4-mini", "gpt-5"],
      "reasoningEffort": "low",
      "note": "Budget-friendly, SWE-bench 68.1%, o4-mini supports low/medium/high effort"
    }
  },
  "agents": {
    "subAgents": {
      "enabled": true,
      "builtIns": [
        "security-reviewer",
        "test-writer",
        "doc-generator",
        "researcher",
        "evolve-researcher"
      ]
    },
    "custom": {},
    "affinityLearning": {
      "enabled": true,
      "decayFactor": 0.9,
      "minSampleSize": 5
    }
  },
  "evolve": {
    "maxRounds": 3,
    "maxHours": 4,
    "focusAreas": [
      "orchestration-patterns",
      "ai-coding-tools",
      "testing-reliability",
      "developer-experience",
      "model-routing",
      "daemon-architecture"
    ],
    "budget": {
      "softLimit": 600000,
      "hardLimit": 800000,
      "perRoundEstimate": 200000,
      "warnThreshold": 0.6,
      "reduceScopeThreshold": 0.75,
      "softStopThreshold": 0.85,
      "hardStopThreshold": 0.95
    },
    "phases": {
      "researchTimeoutMs": 300000,
      "deliberateTimeoutMs": 420000,
      "planTimeoutMs": 300000,
      "testTimeoutMs": 600000,
      "implementTimeoutMs": 900000,
      "analyzeTimeoutMs": 420000
    },
    "approval": {
      "minScore": 7,
      "requireAllTestsPass": true,
      "requireNoViolations": true
    },
    "baseBranch": "dev",
    "investigator": {
      "enabled": true,
      "model": "gpt-5.2",
      "reasoningEffort": "high",
      "maxAttemptsPerPhase": 2,
      "phases": ["test", "implement", "analyze", "agent"],
      "maxTokensBudget": 50000,
      "tryAlternativeAgent": true,
      "logToFile": true
    },
    "suggestions": {
      "enabled": true,
      "autoPopulateFromRejected": true,
      "autoPopulateFromDeferred": true,
      "maxPendingSuggestions": 50,
      "maxAttemptsPerSuggestion": 3
    }
  },
  "github": {
    "enabled": false,
    "defaultBase": "",
    "draft": false,
    "labels": [],
    "reviewers": [],
    "prBodyFooter": "",
    "requiredChecks": [],
    "autolabel": {}
  },
  "forge": {
    "enabled": true,
    "autoTest": false,
    "phaseTimeoutMs": 300000,
    "storageDir": "docs/coordination/forge"
  },
  "tasks": {
    "maxTasks": 10,
    "maxHours": 2,
    "perTaskTimeoutMs": 900000,
    "baseBranch": "dev",
    "sources": {
      "todoComments": true,
      "todoMd": true,
      "githubIssues": true
    },
    "budget": {
      "defaultPreset": "medium",
      "perTaskEstimate": 100000
    },
    "councilLite": {
      "enabled": true,
      "complexOnly": true
    },
    "investigator": {
      "enabled": true
    }
  },
  "nightly": {
    "enabled": true,
    "baseBranch": "dev",
    "branchPrefix": "nightly",
    "maxTasks": 5,
    "maxHours": 6,
    "perTaskTimeoutMs": 900000,
    "sources": {
      "todoMd": true,
      "todoComments": true,
      "githubIssues": true,
      "configTasks": true,
      "aiDiscovery": true
    },
    "aiDiscovery": {
      "agent": "gemini",
      "maxSuggestions": 5,
      "focus": [],
      "timeoutMs": 300000
    },
    "budget": {
      "softLimit": 400000,
      "hardLimit": 500000,
      "perTaskEstimate": 80000,
      "handoffThreshold": 0.7,
      "handoffAgent": "codex",
      "handoffModel": "o4-mini"
    },
    "tasks": [],
    "investigator": {
      "enabled": true
    },
    "tokenBudget": {
      "softLimit": 400000,
      "hardLimit": 500000,
      "perTaskEstimate": 80000,
      "handoffThreshold": 0.7,
      "warningThreshold": 0.5
    },
    "perTaskTimeoutMin": 15,
    "handoffModel": "o4-mini"
  },
  "audit": {
    "maxFiles": 200,
    "categories": ["dead-code", "inconsistencies", "architecture", "security", "tests", "types"],
    "reportDir": "docs/audit",
    "timeout": 300000,
    "economy": false
  },
  "workers": {
    "permissionMode": "auto-edit",
    "autoStart": true,
    "pollIntervalMs": 1500,
    "maxOutputBufferKB": 8,
    "autoChain": true,
    "heartbeatIntervalMs": 30000,
    "heartbeatTimeoutMs": 90000,
    "retry": {
      "maxAttempts": 3,
      "backoff": {
        "baseDelayMs": 5000,
        "maxDelayMs": 60000
      }
    },
    "deadLetter": {
      "enabled": true
    },
    "concurrency": {
      "maxInFlight": 3,
      "adaptivePolling": true
    }
  },
  "providers": {
    "openai": {
      "adminKey": null,
      "tier": 3
    },
    "anthropic": {
      "adminKey": null,
      "tier": 1
    },
    "google": {
      "tier": 1
    },
    "rateLimit": {
      "openai": 60,
      "anthropic": 50,
      "google": 300
    }
  },
  "doctor": {
    "enabled": true,
    "autoCreateTasks": true,
    "autoCreateSuggestions": true,
    "addToKnowledgeBase": true,
    "recurringThreshold": 3,
    "recurringWindowDays": 7
