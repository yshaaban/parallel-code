# Parallel Code — Environment Variables
# Copy this file to .env and customize as needed.

# Server mode (npm run server)
# PORT=3000
# AUTH_TOKEN=                          # Set for a persistent auth token; omit for random per-session

# Data directory for server mode (defaults to .server-data/)
# PARALLEL_CODE_USER_DATA_DIR=

# Latency simulation (development/testing only)
# SIMULATE_LATENCY_MS=0
# SIMULATE_JITTER_MS=0
# SIMULATE_PACKET_LOSS=0
